{
  "name": "vocabulary-app-workspace",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently \"npm run start:dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "build:backend": "npm run prisma:generate --prefix backend && npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "lint:backend": "npm run lint --prefix backend",
    "lint:frontend": "npm run lint --prefix frontend"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "jwt-decode": "^4.0.0",
    "react-router-dom": "^7.9.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^15.4.3"
  }
}
